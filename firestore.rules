rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: welfare_info
    // Fields:
    //   - category: string (required) - Category of info
    //   - title: string (required) - Title of info
    //   - content: string (required) - HTML content
    //
    // Collection: users
    // Fields:
    //   - role: string (optional) - User role (admin/user)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sj91257759@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidWelfareInfo(data) {
      return data.category is string && data.category.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.content is string && data.content.size() > 0;
    }

    match /welfare_info/{infoId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidWelfareInfo(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
